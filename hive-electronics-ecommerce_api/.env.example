PORT=4000
MONGODB_URI=mongodb://localhost:27017/hiveElectronicsDB
JWT_SECRET=your_jwt_secret_here
JWT_REFRESH_TOKEN=your_jwt_refresh_token_here
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# Swagger UI (/api-docs) is served whenever NODE_ENV is not "production".
# Set ENABLE_DOCS=true to also expose it when NODE_ENV=production.
ENABLE_DOCS=false

# Comma-separated list of allowed CORS origins (e.g. the deployed frontend URL).
CORS_ORIGIN=http://localhost:3000
