      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.0",
    "@vitest/coverage-v8": "^4.1.9",
    "cypress": "^15.18.0",
    "jsdom": "^29.1.1",
